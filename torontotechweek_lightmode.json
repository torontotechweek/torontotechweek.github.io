{
	"version": 8,
	"name": "osm",
	"metadata": {
		"maputnik:renderer": "mbgljs"
	},
	"glyphs": "https://torontotechweek.github.io/assets/fonts/{fontstack}/{range}.pbf",
	"sprite": "https://torontotechweek.github.io/assets/sprites/sprites",
	"sources": {
		"osm": {
			"type": "vector",
			"url": "https://vector.openstreetmap.org/shortbread_v1/tilejson.json"
		},
		"toronto_buildings": {
			"type": "vector",
			"tiles": ["https://torontotechweek.github.io/data/toronto_buildings/{z}/{x}/{y}.pbf"]
		},
		"toronto_neighborhoods_centroids": {
			"type": "geojson",
			"data": "https://torontotechweek.github.io/data/toronto_neighborhoods_centroids.geojson"
		}
	},
	"layers": [
		{
			"id": "background",
			"type": "background",
			"paint": {
				"background-color": "#EEEDEA"
			}
		},
		{
			"source": "osm",
			"id": "water",
			"type": "fill",
			"source-layer": "water_polygons",
			"filter": [ "in", "kind", "water", "river", "reservoir", "basin", "dock" ],
			"paint": {
				"fill-color": "#04304C"
			}
		},
		{
			"source": "osm",
			"id": "waterway",
			"type": "line",
			"source-layer": "water_lines",
			"filter": [ "all", [ "in", "kind", "river" ], [ "!=", "tunnel", true ], [ "!=", "bridge", true ] ],
			"paint": {
				"line-color": "#04304C",
				"line-width": 1,
				"line-opacity": { "stops": [ [ 5, 0 ], [ 6, 1 ] ] }
			}
		},
		{
			"id": "ferry",
			"type": "line",
			"source": "osm",
			"source-layer": "ferries",
			"paint": {
			  "line-color": "hsl(200, 100%, 60%)",
			  "line-dasharray": [2, 2],
			  "line-width": 1
			}
		},
		{
			"source": "osm",
			"id": "highway-minor",
			"type": "line",
			"source-layer": "streets",
			"filter": [ "in", "kind", "unclassified", "residential", "living_street" ],
			"paint": {
				"line-color": "#04304C",
				"line-width": [ "interpolate", [ "linear" ], [ "zoom" ], 14, 0, 16, 1 ],
				"line-opacity": [ "interpolate", [ "linear" ], [ "zoom" ], 14, 0, 15, 1 ]
			},
			"layout": {
				"line-join": "round",
				"line-cap": "round"
			},
			"minzoom": 14
		},
		{
			"source": "osm",
			"id": "highway-major",
			"type": "line",
			"source-layer": "streets",
			"filter": [ "in", "kind", "motorway", "trunk", "primary", "secondary", "tertiary" ],
			"paint": {
				"line-color": "#04304C",
				"line-width": [ "interpolate", [ "linear" ], [ "zoom" ], 11, 0, 13, 1 ],
				"line-opacity": [ "interpolate", [ "linear" ], [ "zoom" ], 11, 0, 12, 1 ]
			},
			"layout": {
				"line-join": "round",
				"line-cap": "round"
			},
			"minzoom": 11
		},
		{
			"source": "osm",
			"id": "railway-outline",
			"type": "line",
			"source-layer": "streets",
			"filter": [ "all", [ "in", "kind", "rail" ], [ "!=", "bridge", true ], [ "!=", "tunnel", true ] ],
			"paint": {
				"line-color": "#04304C",
				"line-width": { "stops": [ [ 8, 1 ], [ 13, 1 ], [ 15, 3 ], [ 16, 4 ], [ 18, 8 ], [ 19, 11 ], [ 20, 14 ] ] },
				"line-opacity": { "stops": [ [ 14, 0 ], [ 15, 1 ] ] }
			}
		},
		{
			"source": "osm",
			"id": "railway",
			"type": "line",
			"source-layer": "streets",
			"filter": [ "all", [ "in", "kind", "rail" ], [ "!=", "bridge", true ], [ "!=", "tunnel", true ] ],
			"paint": {
				"line-color": "#EEEDEA",
				"line-width": { "stops": [ [ 8, 1 ], [ 13, 1 ], [ 15, 2 ], [ 16, 3 ], [ 18, 6 ], [ 19, 8 ], [ 20, 10 ] ] },
				"line-dasharray": [ 2, 2 ],
				"line-opacity": { "stops": [ [ 14, 0 ], [ 15, 1 ] ] }
			}
		},
		{
			"id": "buildings-outline",
			"source": "toronto_buildings",
			"source-layer": "toronto_buildings",
			"type": "line",
			"paint": {
				"line-color": "#04304C",
				"line-width": 0.5,
				"line-opacity": ["interpolate", ["linear"], ["zoom"], 16, 0, 18, 1]
			},
			"minzoom": 16
		},
		{
			"id": "buildings",
			"source": "toronto_buildings",
			"source-layer": "toronto_buildings",
			"type": "fill-extrusion",
			"paint": {
				"fill-extrusion-color": "#EEEDEA",
				"fill-extrusion-height": [
					"case",
					["!=", ["get", "max_height"], null], ["get", "max_height"],
					["!=", ["get", "avg_height"], null], ["get", "avg_height"],
					10
				],
				"fill-extrusion-base": 0,
				"fill-extrusion-opacity": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 0.7, 17, 0.7, 18, 0]
			},
			"minzoom": 15
		},
		{
			"source": "osm",
			"id": "highway-name-minor",
			"type": "symbol",
			"source-layer": "street_labels",
			"filter": [ "in", "kind", "unclassified", "residential", "living_street" ],
			"layout": {
				"text-field": "{name}",
				"text-transform": "uppercase",
				"text-rotation-alignment": "map",
				"text-font": [ "volksans-regular" ],
				"text-letter-spacing": 0.2,
				"text-allow-overlap": false,
				"text-ignore-placement": true,
				"symbol-placement": "line",
				"text-anchor": "bottom",
				"text-size": [ "interpolate", [ "exponential", 1.5 ], [ "zoom" ], 10, 0, 20, 25 ],
				"symbol-sort-key": 100
			},
			"paint": {
				"text-color": "#04304C",
				"text-opacity": [ "interpolate", [ "linear" ], [ "zoom" ], 14, 0, 15, 1 ]
			},
			"minzoom": 15
		},
		{
			"source": "osm",
			"id": "highway-name-major",
			"type": "symbol",
			"source-layer": "street_labels",
			"filter": [ "in", "kind", "motorway", "trunk", "primary", "secondary", "tertiary" ],
			"layout": {
				"text-field": "{name}",
				"text-transform": "uppercase",
				"text-rotation-alignment": "map",
				"text-font": [ "volksans-regular" ],
				"text-letter-spacing": 0.2,
				"text-allow-overlap": false,
				"text-ignore-placement": true,
				"symbol-placement": "line",
				"text-anchor": "bottom",
				"text-size": [ "interpolate", [ "exponential", 1.5 ], [ "zoom" ], 10, 0, 20, 30 ],
				"symbol-sort-key": 100
			},
			"paint": {
				"text-color": "#04304C",
				"text-opacity": [ "interpolate", [ "linear" ], [ "zoom" ], 14, 0, 15, 1 ]
			},
			"minzoom": 15
		},
		{
			"source": "osm",
			"id": "poi-amenity",
			"type": "symbol",
			"source-layer": "pois",
			"filter": [ "all", [ "to-boolean", [ "get", "amenity" ] ], ["!=", ["get", "name"], null] ],
			"layout": {
				"icon-size": 0.6,
				"symbol-placement": "point",
				"icon-optional": true,
				"icon-image": [ "match", [ "get", "amenity" ], "arts_centre", "icon-art_gallery", "atm", "icon-atm", "bank", "icon-bank", "bar", "icon-bar", "bench", "icon-bench", "bicycle_rental", "icon-bicycle_share", "biergarten", "icon-beergarden", "cafe", "icon-cafe", "car_rental", "icon-car_rental", "car_sharing", "icon-car_rental", "car_wash", "icon-car_wash", "cinema", "icon-cinema", "college", "icon-college", "community_centre", "icon-community", "dentist", "icon-dentist", "doctors", "icon-doctor", "dog_park", "icon-dog_park", "drinking_water", "icon-drinking_water", "embassy", "icon-embassy", "fast_food", "icon-fast_food", "fire_station", "icon-fire_station", "fountain", "icon-fountain", "grave_yard", "icon-cemetery", "hospital", "icon-hospital", "hunting_stand", "icon-huntingstand", "library", "icon-library", "marketplace", "icon-marketplace", "nightclub", "icon-nightclub", "nursing_home", "icon-nursinghome", "pharmacy", "icon-pharmacy", "place_of_worship", "icon-place_of_worship", "playground", "icon-playground", "police", "icon-police", "post_box", "icon-postbox", "post_office", "icon-post", "prison", "icon-prison", "pub", "icon-beer", "recycling", "icon-recycling", "restaurant", "icon-restaurant", "school", "icon-school", "shelter", "icon-shelter", "telephone", "icon-telephone", "theatre", "icon-theatre", "toilets", "icon-toilet", "townhall", "icon-town_hall", "vending_machine", "icon-vendingmachine", "veterinary", "icon-veterinary", "waste_basket", "icon-waste_basket", "unknown" ],
				"text-font": [ "montserrat-semibold" ],
				"text-size": 10,
				"text-field": ["get", "name"],
				"text-max-width": 8,
				"text-line-height": 1,
				"icon-anchor": "bottom",
				"text-anchor": "top",
				"icon-allow-overlap": false,
				"text-allow-overlap": false,
				"icon-ignore-placement": false,
				"text-ignore-placement": false
			},
			"paint": {
				"icon-opacity": [ "interpolate", [ "linear" ], [ "zoom" ], 15, 0, 16, 0.8 ],
				"text-opacity": [ "interpolate", [ "linear" ], [ "zoom" ], 15, 0, 16, 0.8 ],
				"icon-color": [
					"case",
					["==", ["get", "amenity"], "bicycle_rental"], "#04304C",
					"#04304C"
				],
				"text-color": [
					"case",
					["==", ["get", "amenity"], "bicycle_rental"], "#04304C",
					"#04304C"
				],
				"text-halo-color": "#EEEDEA",
				"text-halo-width": 0,
				"text-halo-blur": 0
			},
			"minzoom": 15
		},
		{
			"source": "osm",
			"id": "symbol-transit",
			"type": "symbol",
			"source-layer": "public_transport",
			"filter": [ "in", "kind", "bus_stop", "tram_stop", "light_rail" ],
			"layout": {
				"text-field": "{name}",
				"icon-size": 0.6,
				"symbol-placement": "point",
				"text-font": [ "montserrat-semibold" ],
				"text-size": 10,
				"icon-anchor": "bottom",
				"text-anchor": "top",
				"icon-image": "icon-bus",
				"icon-allow-overlap": false,
				"text-allow-overlap": false,
				"icon-ignore-placement": false,
				"text-ignore-placement": false
			},
			"paint": {
				"icon-opacity": [ "interpolate", [ "linear" ], [ "zoom" ], 14, 0, 15, 0.8 ],
				"text-opacity": [ "interpolate", [ "linear" ], [ "zoom" ], 14, 0, 15, 0.8 ],
				"icon-color": "#D74417",
				"text-color": "#D74417",
				"text-halo-color": "#EEEDEA",
				"text-halo-width": 0,
				"text-halo-blur": 0
			},
			"minzoom": 14
		},
		{
			"source": "osm",
			"id": "symbol-transit-subway",
			"type": "symbol",
			"source-layer": "public_transport",
			"filter": [ "in", "kind", "station" ],
			"layout": {
				"text-field": "{name}",
				"icon-size": 0.6,
				"symbol-placement": "point",
				"text-font": [ "montserrat-semibold" ],
				"text-size": 10,
				"icon-anchor": "bottom",
				"text-anchor": "top",
				"icon-image": "icon-rail_metro",
				"icon-allow-overlap": true,
				"text-allow-overlap": true,
				"icon-ignore-placement": false,
				"text-ignore-placement": false
			},
			"paint": {
				"icon-opacity": [ "interpolate", [ "linear" ], [ "zoom" ], 13, 0, 14, 0.8 ],
				"text-opacity": [ "interpolate", [ "linear" ], [ "zoom" ], 13, 0, 14, 0.8 ],
				"icon-color": "#D74417",
				"text-color": "#D74417",
				"text-halo-color": "#EEEDEA",
				"text-halo-width": 0,
				"text-halo-blur": 0
			},
			"minzoom": 13
		},
		{
			"id": "neighborhoods-labels",
			"type": "symbol",
			"source": "toronto_neighborhoods_centroids",
			"layout": {
				"text-field": ["get", "area_name"],
				"text-size": ["interpolate", ["exponential", 1.1], ["zoom"], 10, 1, 18, 50],
				"text-font": ["volksans-regular"],
				"text-max-width": 5,
				"text-line-height": 1,
				"text-allow-overlap": true,
				"text-ignore-placement": true,
				"text-rotation-alignment": "viewport",
				"text-pitch-alignment": "viewport"
			},
			"paint": {
				"text-color": "#04304C",
				"text-opacity": ["interpolate", ["linear"], ["zoom"], 11, 0, 12, 0.4, 14, 0.4, 16, 0]
			},
			"minzoom": 11,
			"maxzoom": 16
		}
	]
}